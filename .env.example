# ============================================
# Google Gemini API (for AI features)
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# WalletConnect (Web3 Modal)
# ============================================
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ============================================
# Supabase Database & Auth
# ============================================
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_KEY=your_supabase_anon_key_here

# ============================================
# OpenClaw / MiniMax AI API
# ============================================
VITE_OPENCLAW_TOKEN=your_openclaw_token_here
VITE_OPENCLAW_MODEL=MiniMax-M2.5
VITE_OPENCLAW_URL=/v1/chat/completions

# ============================================
# File Processing Service (PDFs, Documents)
# ============================================
VITE_EXTRACTOR_URL=http://localhost:3010

# ============================================
# Backend Server Configuration
# ============================================
PORT=3003
OPENCLAW_HOST=127.0.0.1
OPENCLAW_PORT=18789
OPENCLAW_TOKEN=your_openclaw_token_here
JINA_URL=https://r.jina.ai/

# ============================================
# Application URLs
# ============================================
VITE_APP_URL=https://ethv.io
VITE_APP_ENVIRONMENT=development

# ============================================
# Feature Flags
# ============================================
VITE_ENABLE_WEB3=true
VITE_ENABLE_LINKEDIN_SCRAPER=true
VITE_ENABLE_PDF_ANALYSIS=true

# ============================================
# Development Mode - Bypass Wallet Auth
# Set to 'true' to access protected routes without Web3 authentication
# Example: /upload, /dashboard, /validation, /opportunities
# ============================================
VITE_WALLET_BYPASS=false
