// ETHV OpenClaw Service - Fast OCR Backend Integration
const OCR_URL = 'http://localhost:3020';

function log(level, message, data) {
  console.log('[ETHV]', JSON.stringify({level, message, data}));
}

log('INFO', 'Service loaded - Using OCR Backend');

// OpenClaw API function
async function sendToAgent(message) {
  const token = 'bd1177ff2d28a2c4ceew1e08fee975fc9';

  const response = await fetch('/v1/chat/completions', {
    method: 'POST',
    headers: {
      'Authorization': 'Bearer ' + token,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      model: 'MiniMax-M2.5',
      messages: [{ role: 'user', content: message }],
      max_tokens: 2000
    })
  });

  if (!response.ok) throw new Error('API Error: ' + response.status);
  return response.json();
}

// Convert file to base64
function fileToBase64(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = () => resolve(reader.result.split(',')[1]);
    reader.onerror = reject;
    reader.readAsDataURL(file);
  });
}

// Main CV analysis - Uses OCR backend for PDFs and images
async function analyzeCV(file) {
  log('INFO', 'analyzeCV called', {fileName: file.name, fileType: file.type, fileSize: file.size});
  
  let extractedText = '';
  
  // Check if file is PDF or image - use OCR backend
  const isPDF = file.type === 'application/pdf' || file.name.toLowerCase().endsWith('.pdf');
  const isImage = file.type.startsWith('image/');
  
  if (isPDF || isImage) {
    try {
      log('INFO', 'Converting file to base64...');
      const base64 = await fileToBase64(file);
      
      log('INFO', 'Sending to OCR backend...', {isPDF, base64Length: base64.length});
      
      const ocrRes = await fetch(OCR_URL + '/extract-base64', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ base64, isPDF })
      });
      
      if (ocrRes.ok) {
        const ocrData = await ocrRes.json();
        extractedText = ocrData.text;
        log('INFO', 'OCR extracted', {length: extractedText.length});
      } else {
        const err = await ocrRes.text();
        log('ERROR', 'OCR failed', {status: ocrRes.status, error: err});
      }
    } catch (e) {
      log('ERROR', 'OCR exception', {error: e.message});
    }
  }
  
  // Send to OpenClaw for analysis
  const prompt = extractedText 
    ? `You are ETHV, a Web3 talent validation agent. Extract JSON from this CV: {skills: [], experience_years: 0, education: [], certifications: [], summary: "", web3_relevance: "low"} CV Text: ${extractedText.substring(0, 4000)}`
    : `You are ETHV, a Web3 talent validation agent. Analyze this file and extract JSON: {skills: [], experience_years: 0, education: [], certifications: [], summary: "", web3_relevance: "low"} File: ${file.name}, Size: ${file.size} bytes`;

  log('INFO', 'Sending to OpenClaw...');
  const result = await sendToAgent(prompt);
  const content = result.choices ? result.choices[0].message.content : '';
  
  try {
    const match = content.match(/\{[\s\S]*\}/);
    if (match) return JSON.parse(match[0]);
  } catch (e) {
    log('ERROR', 'JSON parse failed', {error: e.message});
  }
  
  return { skills: [], experience_years: 0, summary: content || 'Analysis complete' };
}

// Analyze profile content (text/LinkedIn)
async function analyzeProfileContent(content) {
  const prompt = 'You are ETHV, a Web3 talent validation agent. Extract JSON: {skills: [], experience_years: 0, education: [], certifications: [], summary: "", web3_relevance: "low"} Content: ' + content.slice(0, 5000);

  const result = await sendToAgent(prompt);
  const text = result.choices ? result.choices[0].message.content : '';
  
  try {
    const match = text.match(/\{[\s\S]*\}/);
    if (match) return JSON.parse(match[0]);
  } catch (e) {}
  
  return { summary: text, skills: [], web3_relevance: 'low' };
}

// Check OCR connection
async function checkConnection() {
  try {
    const res = await fetch(OCR_URL + '/health');
    return res.ok;
  } catch { return false; }
}

function clearLogs() {
  console.log('[ETHV] Logs cleared');
}

function getLogs() {
  return [];
}

export { sendToAgent, analyzeCV, analyzeProfileContent, checkConnection, log, clearLogs, getLogs };
