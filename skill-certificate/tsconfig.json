{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "commonjs",
    "esModuleInterop":  true,
    "strict":           true,
    "outDir":           "./dist",
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck":     true
  },
  "include": [
    "./hardhat.config.ts",
    "./scripts/**/*.ts",
    "./deploy/**/*.ts",
    "./test/**/*.ts",
    "./typechain-types/**/*.ts"
  ]
}
