{
  "name": "skill-certificate",
  "version": "1.0.0",
  "description": "Soulbound NFT skill certificates on zkSYS Testnet",
  "scripts": {
    "compile":    "hardhat compile",
    "compile:zk": "hardhat compile --network zkSYSTestnet",
    "test":       "hardhat test --network hardhat",
    "deploy":     "hardhat deploy-zksync --script deploy.ts --network zkSYSTestnet",
    "verify":     "hardhat verify --network zkSYSTestnet",
    "clean":      "hardhat clean"
  },
  "devDependencies": {
    "@matterlabs/hardhat-zksync-deploy":  "^1.3.0",
    "@matterlabs/hardhat-zksync-solc":    "^1.2.4",
    "@matterlabs/hardhat-zksync-verify":  "^1.5.0",
    "@nomicfoundation/hardhat-toolbox":   "^5.0.0",
    "@types/node":                        "^20.0.0",
    "hardhat":                            "^2.22.0",
    "ts-node":                            "^10.9.2",
    "typescript":                         "^5.4.5"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.6",
    "dotenv":                  "^16.4.5",
    "ethers":                  "^6.11.1",
    "zksync-ethers":           "^6.12.0"
  }
}
