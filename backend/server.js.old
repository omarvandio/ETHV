const express = require('express');
const { Client, GatewayIntentBits } = require('discord.js');
const { handleMessage } = require('./commands');
const { evaluateSurvival } = require('./survival-rules');

const app = express();
app.use(express.json());
const PORT = process.env.PORT || 3000;

// CORS middleware
app.use((req, res, next) => {
  res.header('Access-Control-Allow-Origin', '*');
  res.header('Access-Control-Allow-Methods', 'GET, POST, OPTIONS');
  res.header('Access-Control-Allow-Headers', 'Content-Type, Authorization');
  if (req.method === 'OPTIONS') return res.sendStatus(200);
  next();
});

// Discord bot
const client = new Client({
  intents: [
    GatewayIntentBits.Guilds,
    GatewayIntentBits.GuildMessages,
    GatewayIntentBits.MessageContent,
  ]
});

client.on('ready', () => {
  console.log(\[ETHV] Bot online: \\);
});

client.on('messageCreate', async (message) => {
  if (message.author.bot) return;
  if (!message.content.startsWith('/')) return;

  const response = await handleMessage({
    text: message.content,
    userId: message.author.id,
    channelId: message.channelId,
  });

  if (response?.text) {
    await message.channel.send(response.text);
  }
});

// Health check
app.get('/', (req, res) => res.json({ agent: 'ETHV', status: 'online' }));

app.get('/health', (req, res) => res.json({ status: 'ok', agent: 'ETHV' }));

// Chat completions endpoint (proxies to OpenClaw gateway)
app.post('/v1/chat/completions', async (req, res) => {
  try {
    const { model, messages, max_tokens } = req.body;
    
    // Forward to OpenClaw gateway
    const gatewayUrl = process.env.OPENCLAW_URL || 'http://localhost:18789';
    const gatewayToken = process.env.OPENCLAW_TOKEN || 'bd1177ff2d28a2c4ceew1e08fee975fc9';
    
    const response = await fetch(\\/v1/chat/completions\, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': \Bearer \\
      },
      body: JSON.stringify({ model, messages, max_tokens })
    });
    
    if (!response.ok) {
      const errorText = await response.text();
      console.error('[ETHV] Gateway error:', response.status, errorText);
      return res.status(response.status).json({ error: errorText });
    }
    
    const data = await response.json();
    res.json(data);
  } catch (error) {
    console.error('[ETHV] Chat completions error:', error.message);
    res.status(500).json({ error: error.message });
  }
});

// LinkedIn analysis endpoint
app.post('/api/analyze-linkedin', async (req, res) => {
  try {
    const { url } = req.body;
    
    if (!url) {
      return res.status(400).json({ error: 'URL is required' });
    }
    
    // Forward to OpenClaw gateway for analysis
    const gatewayUrl = process.env.OPENCLAW_URL || 'http://localhost:18789';
    const gatewayToken = process.env.OPENCLAW_TOKEN || 'bd1177ff2d28a2c4ceew1e08fee975fc9';
    
    const prompt = \Eres ETHV. Analiza este LinkedIn y extrae: skills, experience_years, education, certifications, summary, headline, location en JSON. URL: \\;
    
    const response = await fetch(\\/v1/chat/completions\, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': \Bearer \\
      },
      body: JSON.stringify({
        model: 'MiniMax-M2.5',
        messages: [{ role: 'user', content: prompt }],
        max_tokens: 2000
      })
    });
    
    if (!response.ok) {
      const errorText = await response.text();
      return res.status(response.status).json({ error: errorText });
    }
    
    const data = await response.json();
    const content = data?.choices?.[0]?.message?.content || '';
    
    // Extract JSON from response
    try {
      const jsonMatch = content.match(/\{[\s\S]*\}/);
      if (jsonMatch) {
        const parsed = JSON.parse(jsonMatch[0]);
        return res.json(parsed);
      }
    } catch (e) {
      console.error('[ETHV] JSON parse error:', e);
    }
    
    // Fallback if no JSON found
    res.json({ 
      skills: [], 
      experience_years: 0, 
      education: [], 
      certifications: [], 
      summary: content || 'Analysis complete', 
      headline: '', 
      location: '' 
    });
  } catch (error) {
    console.error('[ETHV] LinkedIn analysis error:', error.message);
    res.status(500).json({ error: error.message });
  }
});

app.listen(PORT, () => console.log(\[ETHV] Server en puerto \\));

const token = process.env.DISCORD_BOT_TOKEN;
if (token) {
  client.login(token);
} else {
  console.error('[ETHV] DISCORD_BOT_TOKEN no configurado');
}
