# ============================================
# LIKETAL BACKEND — Variables de entorno
# Copia este archivo a .env y rellena los valores
# ============================================

# ============================================
# Servidor
# ============================================
PORT=3003

# ============================================
# AI Provider
# Soporta: anthropic (MiniMax/Claude) | openai (GPT-4o, DeepSeek, Grok...)
# Cambia las 4 líneas siguientes para cambiar de proveedor sin tocar código.
# ============================================
AI_PROVIDER=anthropic
AI_BASE_URL=https://api.minimax.io/anthropic
AI_API_KEY=your_minimax_or_anthropic_api_key_here
AI_MODEL=MiniMax-M2.5

# --- Ejemplos de otros proveedores ---
# Claude (Anthropic):
#   AI_PROVIDER=anthropic
#   AI_BASE_URL=https://api.anthropic.com
#   AI_API_KEY=sk-ant-...
#   AI_MODEL=claude-sonnet-4-6

# GPT-4o (OpenAI):
#   AI_PROVIDER=openai
#   AI_BASE_URL=https://api.openai.com
#   AI_API_KEY=sk-...
#   AI_MODEL=gpt-4o

# DeepSeek:
#   AI_PROVIDER=openai
#   AI_BASE_URL=https://api.deepseek.com
#   AI_API_KEY=sk-...
#   AI_MODEL=deepseek-chat

# Grok (xAI):
#   AI_PROVIDER=openai
#   AI_BASE_URL=https://api.x.ai
#   AI_API_KEY=xai-...
#   AI_MODEL=grok-3

# ============================================
# Jina AI — scraping de LinkedIn
# No requiere key (free tier con la URL base)
# ============================================
JINA_URL=https://r.jina.ai/

# ============================================
# Supabase (opcional — para guardar historial de análisis)
# Obtén las keys en: https://supabase.com → Settings → API
# ============================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# ============================================
# zkSYS — Wallet para mintear certificados NFT
# La misma que deployó el contrato SkillCertificate
# ============================================
ZKSYS_PRIVATE_KEY=tu_clave_privada_zksys_aqui

# ============================================
# SuperDapp Agent — Webhook en /webhook (puerto 3003)
# SUPERDAPP_TOKEN: dashboard de SuperDapp al registrar el bot
# GROQ_API_KEY: https://console.groq.com → API Keys
# ============================================
SUPERDAPP_TOKEN=tu_superdapp_token_aqui
GROQ_API_KEY=tu_groq_api_key_aqui

# ============================================
# OAuth — Google
# Crear en: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3003/auth/google/callback
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ============================================
# OAuth — LinkedIn
# Crear en: https://www.linkedin.com/developers/apps → Auth tab
# Authorization callback URL: http://localhost:3003/auth/linkedin/callback
# Scopes requeridos: openid, profile, email
# ============================================
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# ============================================
# OAuth — GitHub
# Crear en: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Homepage URL:             http://localhost:3000
# Authorization callback URL: http://localhost:3003/auth/github/callback
# ============================================
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ============================================
# URLs (para redirects de OAuth)
# Cambiar en producción por las URLs reales
# ============================================
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3003




ZKSYS_PRIVATE_KEY=0x2....