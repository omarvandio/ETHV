{
  "name": "liketalent-backend",
  "version": "1.0.0",
  "description": "LikeTalent API - CV analysis, LinkedIn scraping, AI talent validation",
  "main": "index.cjs",
  "scripts": {
    "start": "node index.cjs",
    "dev": "node --watch index.cjs",
    "postinstall": "node -e \"const fs=require('fs'),p='node_modules/@superdapp/agents/package.json',d=JSON.parse(fs.readFileSync(p,'utf8'));delete d.type;fs.writeFileSync(p,JSON.stringify(d,null,2));console.log('[@superdapp/agents] patched type:module');\""
  },
  "dependencies": {
    "@superdapp/agents": "^1.0.2",
    "axios": "^1.7.9",
    "discord.js": "^14.16.3",
    "canvas": "^3.2.1",
    "cors": "^2.8.6",
    "docx": "^9.5.0",
    "dotenv": "^17.2.3",
    "ethers": "^6.16.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.5.207",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tesseract.js": "^7.0.0",
    "zksync-ethers": "^6.21.1"
  }
}
